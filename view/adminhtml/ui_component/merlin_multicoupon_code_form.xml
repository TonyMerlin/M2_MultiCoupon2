<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">merlin_multicoupon_code_form.merlin_multicoupon_code_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Deal Code</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>

    <settings>
        <namespace>merlin_multicoupon_code_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>merlin_multicoupon_code_form.merlin_multicoupon_code_form_data_source</dep>
        </deps>
        <buttons>
            <button name="back" class="Merlin\MultiCoupon\Block\Adminhtml\Code\Edit\BackButton"/>
            <button name="delete" class="Merlin\MultiCoupon\Block\Adminhtml\Code\Edit\DeleteButton"/>
            <button name="save" class="Merlin\MultiCoupon\Block\Adminhtml\Code\Edit\SaveButton"/>
            <button name="save_and_continue" class="Merlin\MultiCoupon\Block\Adminhtml\Code\Edit\SaveAndContinueButton"/>
        </buttons>
    </settings>

    <dataSource name="merlin_multicoupon_code_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="merlin_multicoupon/code/save"/>
        </settings>
        <dataProvider class="Merlin\MultiCoupon\Ui\DataProvider\Code\FormDataProvider"
                      name="merlin_multicoupon_code_form_data_source">
            <settings>
                <requestFieldName>entity_id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general" sortOrder="10">
        <settings>
            <label translate="true">General</label>
        </settings>

        <field name="entity_id" formElement="hidden">
            <settings>
                <dataType>text</dataType>
                <dataScope>entity_id</dataScope>
            </settings>
        </field>

        <field name="code" sortOrder="10" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Code</label>
                <dataScope>code</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <notice translate="true">Enter any discount code other than OFFER- codes for this extension to allow, for example SPRING10 or VIPPRICE.</notice>
            </settings>
        </field>

        <field name="label" sortOrder="20" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Label</label>
                <dataScope>label</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>

        <field name="is_active" sortOrder="30" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Active</label>
                <dataScope>is_active</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Yesno"/>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="sort_order" sortOrder="40" formElement="input">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Sort Order</label>
                <dataScope>sort_order</dataScope>
            </settings>
        </field>
    </fieldset>
</form>
