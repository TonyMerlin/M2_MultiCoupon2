<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">merlin_multicoupon_code_listing.merlin_multicoupon_code_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <spinner>columns</spinner>
        <deps>
            <dep>merlin_multicoupon_code_listing.merlin_multicoupon_code_listing_data_source</dep>
        </deps>
        <buttons>
            <button name="add">
                <url path="merlin_multicoupon/code/new"/>
                <class>primary</class>
                <label translate="true">Add New Promo Code</label>
            </button>
        </buttons>
    </settings>

    <dataSource name="merlin_multicoupon_code_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">entity_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Merlin_MultiCoupon::codes</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="merlin_multicoupon_code_listing_data_source">
            <settings>
                <requestFieldName>entity_id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="columns">
        <column name="entity_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>

        <column name="code">
            <settings>
                <filter>text</filter>
                <label translate="true">Code</label>
            </settings>
        </column>

        <column name="label">
            <settings>
                <filter>text</filter>
                <label translate="true">Label</label>
            </settings>
        </column>

        <column name="is_active">
            <settings>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Active</label>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
            </settings>
        </column>

        <column name="sort_order">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Sort Order</label>
            </settings>
        </column>

        <actionsColumn name="actions" class="Merlin\MultiCoupon\Ui\Component\Listing\Column\CodeActions">
            <settings>
                <indexField>entity_id</indexField>
                <label translate="true">Actions</label>
            </settings>
        </actionsColumn>
    </columns>
</listing>
