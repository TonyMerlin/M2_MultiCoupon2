<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

<preference for="Magento\Paypal\Model\Api\Nvp"
            type="Merlin\MultiCoupon\Model\Paypal\Api\Nvp"/>

<type name="Magento\Paypal\Model\Cart">
    <plugin name="merlin_multicoupon_paypal_cart_amounts"
            type="Merlin\MultiCoupon\Plugin\Paypal\CartPlugin"
            sortOrder="10"/>
</type>

    <type name="Magento\Checkout\Model\CompositeConfigProvider">
        <arguments>
            <argument name="configProviders" xsi:type="array">
                <item name="merlin_multi_coupon_config_provider" xsi:type="object">Merlin\MultiCoupon\Model\Checkout\ConfigProvider</item>
            </argument>
        </arguments>
    </type>

    <type name="Magento\Quote\Api\CartTotalRepositoryInterface">
        <plugin name="merlin_multi_coupon_totals_extension_attributes"
                type="Merlin\MultiCoupon\Plugin\Checkout\CartTotalRepositoryPlugin"/>
    </type>

    <virtualType name="Merlin\MultiCoupon\Model\ResourceModel\Code\Grid\Collection"
                 type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">merlin_multicoupon_code</argument>
            <argument name="resourceModel" xsi:type="string">Merlin\MultiCoupon\Model\ResourceModel\Code</argument>
        </arguments>
    </virtualType>

    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="merlin_multicoupon_code_listing_data_source" xsi:type="string">Merlin\MultiCoupon\Model\ResourceModel\Code\Grid\Collection</item>
            </argument>
        </arguments>
    </type>

</config>
