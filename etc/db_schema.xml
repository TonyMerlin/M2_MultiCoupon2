<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="quote" resource="checkout">
        <column xsi:type="text"
                name="merlin_multi_coupon_codes"
                nullable="true"
                comment="Merlin Multi Coupon Codes"/>
    </table>

    <table name="sales_order" resource="sales">
        <column xsi:type="text"
                name="merlin_multi_coupon_codes"
                nullable="true"
                comment="Merlin Multi Coupon Codes"/>
    </table>

    <table name="merlin_multicoupon_code"
           resource="default"
           engine="innodb"
           comment="Merlin Multi Coupon Allowed Deal Codes">
        <column xsi:type="int"
                name="entity_id"
                unsigned="true"
                nullable="false"
                identity="true"
                comment="Entity ID"/>
        <column xsi:type="varchar"
                name="code"
                nullable="false"
                length="64"
                comment="Coupon Code"/>
        <column xsi:type="varchar"
                name="label"
                nullable="false"
                length="255"
                comment="Display Label"/>
        <column xsi:type="smallint"
                name="is_active"
                nullable="false"
                default="1"
                comment="Is Active"/>
        <column xsi:type="int"
                name="sort_order"
                nullable="false"
                default="0"
                comment="Sort Order"/>
        <column xsi:type="timestamp"
                name="created_at"
                nullable="false"
                default="CURRENT_TIMESTAMP"
                on_update="false"
                comment="Created At"/>
        <column xsi:type="timestamp"
                name="updated_at"
                nullable="false"
                default="CURRENT_TIMESTAMP"
                on_update="true"
                comment="Updated At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>

        <constraint xsi:type="unique" referenceId="MERLIN_MULTICOUPON_CODE_CODE_UNIQUE">
            <column name="code"/>
        </constraint>

        <index referenceId="MERLIN_MULTICOUPON_CODE_IS_ACTIVE_SORT_ORDER"
               indexType="btree">
            <column name="is_active"/>
            <column name="sort_order"/>
        </index>
    </table>
</schema>
